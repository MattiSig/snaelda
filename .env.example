# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini

# Unsplash
UNSPLASH_APPLICATION_ID=your_unsplash_application_id_here
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
UNSPLASH_SECRET_KEY=your_unsplash_secret_key_here

# Pexels (starter imagery for generation; leave blank to disable)
PEXELS_API_KEY=your_pexels_api_key_here

# Railway
RAILWAY_API_TOKEN=your_railway_api_token_here

# App
APP_ENV=development
HTTP_ADDR=:8080
APP_BASE_URL=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000
PUBLIC_BASE_DOMAIN=localhost
API_BASE_URL=http://localhost:8080
VITE_APP_BASE_URL=http://localhost:3000
EMAIL_TRANSPORT=stdout
EMAIL_FROM_ADDRESS=hi@snaelda.app
EMAIL_FROM_NAME=Snaelda
EMAIL_REPLY_TO=
RESEND_API_KEY=
MAILPIT_SMTP_ADDR=localhost:1025
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_ISSUER=snaelda-api
AUTH_AUDIENCE=snaelda-web
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=720h
AUTH_COOKIE_SECURE=false
PUBLISHED_ARTIFACTS_DIR=var/published-artifacts

# Stripe billing
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_BASIC=price_replace_me
STRIPE_PRICE_PRO=price_replace_me
STRIPE_PRICE_ONCE_OVER=price_replace_me
BILLING_SUCCESS_URL=http://localhost:3000/app/billing/success
BILLING_CANCEL_URL=http://localhost:3000/app/billing/cancel
BILLING_PORTAL_RETURN_URL=http://localhost:3000/app/billing

# Database
DATABASE_URL=postgres://user:password@localhost:5432/snaelda?sslmode=disable

# Storage
S3_ENDPOINT=http://localhost:8333
S3_BUCKET=snaelda-local
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=snaelda
S3_SECRET_ACCESS_KEY=snaelda-secret
S3_FORCE_PATH_STYLE=true

# Local SeaweedFS port overrides
SEAWEEDFS_S3_PORT=8333
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_FILER_PORT=8888
